{
  "name": "gateproof",
  "version": "0.5.1",
  "type": "module",
  "description": "A tiny Effect-first runtime that runs gates from a typed plan until they pass or stop.",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./cloudflare": {
      "types": "./dist/cloudflare/index.d.ts",
      "import": "./dist/cloudflare/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "lint": "bun scripts/lint.ts plan.ts src scripts test examples",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "prove": "bun scripts/run-proof-loop.ts",
    "prove:once": "bun plan.ts",
    "prove:gate": "bun scripts/run-proof-gate.ts",
    "prove:status": "bun scripts/run-proof-status.ts",
    "prove:finalize": "bun scripts/finalize-proof-loop.ts",
    "readme:generate": "bun scripts/generate-readme.ts",
    "example:hello-world": "bun scripts/run-hello-world-example.ts",
    "example:hello-world:worker": "bun scripts/run-hello-world-worker-loop.ts",
    "quality:check": "bun scripts/run-quality-check.ts",
    "plan:validate": "bun scripts/validate-plan.ts",
    "plan:hygiene": "bun scripts/check-gate-hygiene.ts",
    "turn:finalize": "bun scripts/finalize-turn.ts",
    "turn:finalize:push": "bun scripts/finalize-turn.ts --push",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "bun run plan:validate && bun run readme:generate && bun run typecheck && bun run build && bun test"
  },
  "keywords": [
    "gate",
    "plan",
    "runtime",
    "verification",
    "effect"
  ],
  "author": "Jordan Coeyman <jordan@coey.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/acoyfellow/gateproof.git"
  },
  "homepage": "https://github.com/acoyfellow/gateproof#readme",
  "bugs": {
    "url": "https://github.com/acoyfellow/gateproof/issues"
  },
  "dependencies": {
    "effect": "beta"
  },
  "devDependencies": {
    "@types/node": "^24.10.8",
    "bun-types": "^1.3.6",
    "typescript": "^5.9.3"
  }
}
